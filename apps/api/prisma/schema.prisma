generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  /// Null для пользователей, созданных через OAuth без пароля
  password            String?
  role                Role      @default(USER)
  feedToken                  String?   @unique
  refreshToken               String?
  resetToken                 String?   @unique
  resetTokenExpiresAt        DateTime?
  telegramChatId             String?   @unique
  telegramUsername           String?
  telegramLinkToken          String?   @unique
  telegramLinkTokenExpiresAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  userSources     UserSource[]
  userPreferences UserPreferences[]
  userArticles    UserArticle[]
  oauthAccounts   OAuthAccount[]

  @@index([role])
  @@index([createdAt])
  @@map("users")
}

/// OAuth-аккаунты, привязанные к пользователю (Google, GitHub, Yandex и др.)
model OAuthAccount {
  id                String   @id @default(cuid())
  /// Идентификатор провайдера: "google" | "github" | "yandex"
  provider          String
  /// ID пользователя на стороне провайдера
  providerAccountId String
  userId            String
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

enum SourceType {
  RSS
  ATOM
  TELEGRAM
}

model Source {
  id          String     @id @default(cuid())
  url         String     @unique
  title       String
  description String?
  imageUrl    String?
  type        SourceType @default(RSS)
  lastFetchAt DateTime?
  lastError   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  userSources     UserSource[]
  articles        Article[]
  userPreferences UserPreferences[]

  @@map("sources")
}

model UserSource {
  id     String @id @default(cuid())
  userId String

  sourceId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceId])
  @@index([userId])
  @@map("user_sources")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

/**
 * Хранит настройки пользователя в JSONB-поле.
 * sourceId = null → глобальные настройки.
 * sourceId = X    → переопределения для конкретного источника (#21-24).
 *
 * Структура settings:
 * {
 *   relevanceThreshold?: number,     // default 0.6
 *   interestsText?: string | null,
 *   selectedCategories?: string[],   // slugs из таблицы Category
 * }
 */
model UserPreferences {
  id        String   @id @default(cuid())
  userId    String
  sourceId  String?
  settings  Json     @default("{}")
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  source Source? @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceId])
  @@index([userId])
  @@map("user_preferences")
}

model Article {
  id          String    @id @default(cuid())
  sourceId    String
  guid        String
  title       String
  url         String
  content     String?
  /// AI-саммари для RSS-статей (1–2 предл.)
  summary     String?
  /// AI-заголовок для Telegram-постов (генерируется один раз, не перезаписывает оригинальный title)
  aiTitle     String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  source       Source        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  userArticles UserArticle[]

  @@unique([sourceId, guid])
  @@index([sourceId])
  @@map("articles")
}

model UserArticle {
  id                 String    @id @default(cuid())
  userId             String
  articleId          String
  score              Float
  scoreReason        String?
  /// Когда статья была отправлена пользователю в Telegram. null = ещё не отправлена.
  telegramNotifiedAt DateTime?
  createdAt          DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId, score])
  @@index([articleId, userId]) // ускоряет NOT EXISTS в findUnscoredBySource
  @@index([userId, telegramNotifiedAt]) // ускоряет запрос неотправленных статей
  @@map("user_articles")
}
