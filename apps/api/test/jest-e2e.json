{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^p-limit$": "<rootDir>/__mocks__/p-limit.js"
  },
  "setupFilesAfterEnv": ["<rootDir>/setup.ts"]
}
