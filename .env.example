# Переменные окружения используются в трёх местах:
#
#   .env              — подстановка переменных в docker compose (${VAR})
#   apps/api/.env     — локальный запуск NestJS/Prisma без Docker
#   apps/web/.env  — локальный запуск Next.js без Docker
#
# Скопируй этот файл в .env и заполни реальными значениями.
# Для локальной разработки без Docker дополнительно создай:
#   cp .env.example apps/api/.env   (удали web-переменные)
#   cp .env.example apps/web/.env   (удали api-переменные)

# ── Общее ──────────────────────────────────────────────────

# Database (api)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexst_dev?schema=public"

# JWT (api)
JWT_SECRET="change-me-jwt-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Next Auth (web)
NEXTAUTH_SECRET="change-me-nextauth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Межсервисный секрет: защищает внутренние API-эндпоинты от прямых вызовов
# Должен совпадать в apps/api и apps/web
# Сгенерировать: openssl rand -base64 32
INTERNAL_API_SECRET="change-me-internal-secret-min-32-chars"

# API URLs (web)
NEXT_PUBLIC_API_URL="http://localhost:3001"
# Internal API URL для server-side запросов (Docker: http://api:3001)
API_URL="http://localhost:3001"

# URL фронтенда — используется в письмах для ссылки сброса пароля (api)
APP_URL="http://localhost:3000"

# AI провайдер (api) — groq (дефолт) или openrouter
AI_PROVIDER="groq"
# Переопределяет дефолтную модель провайдера (опционально)
# Groq default: llama-3.3-70b-versatile | OpenRouter default: openai/gpt-4o-mini
AI_MODEL=""

# Groq API (используется при AI_PROVIDER=groq)
GROQ_API_KEY="gsk_..."

# OpenRouter API (используется при AI_PROVIDER=openrouter)
# Ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Email (SMTP) (api)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@example.com"
SMTP_PASS="change-me-smtp-password"
SMTP_FROM="Curio <noreply@example.com>"

# Telegram Bot (api) — опционально; фича отключена если не задано
# Получить токен: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=""
# Имя бота без @, например: CurioBot
TELEGRAM_BOT_NAME=""

# OAuth провайдеры (web) — опционально; кнопка скрывается если не задано
# Google: https://console.cloud.google.com/ → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GitHub: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Яндекс: https://oauth.yandex.ru/client/new
YANDEX_CLIENT_ID=""
YANDEX_CLIENT_SECRET=""
