# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexst_dev?schema=public"

# JWT
JWT_SECRET="change-me-jwt-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Next Auth
NEXTAUTH_SECRET="change-me-nextauth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# API
NEXT_PUBLIC_API_URL="http://localhost:3001"
# Internal API URL for server-side requests (Docker: http://api:3001)
API_URL="http://localhost:3001"
